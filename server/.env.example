PORT=3000

# Squad sandbox
SQUAD_BASE_URL=https://sandbox-api-d.squadco.com
SQUAD_SECRET_KEY=sandbox_sk_replace_me
# Your settlement GTBank account (10 digits). Funds sent to any virtual account
# we provision will be swept to this account. Get this from your Squad dashboard.
SQUAD_BENEFICIARY_ACCOUNT=0000000000
# Prefix Squad attaches to your transfer references. Get from your TAM.
SQUAD_MERCHANT_ID=TRADESCORE

# Set to "true" to fake virtual-account creation when Squad refuses (e.g. sandbox
# rate-limit while waiting on support to lift the cap). Real Squad calls resume
# the moment you flip this back to false.
SQUAD_DEMO_MODE=false

# Set to "true" to mock the final /payout/transfer call. The real account
# lookup still happens (so judges can see the recipient resolved from Squad's
# real API), but the transfer is faked because the sandbox merchant wallet
# requires manual top-up from Squad support. Loans created in this mode are
# marked `demo_disbursed` so the UI shows them honestly. Flip to false in
# production with a funded wallet.
SQUAD_DEMO_PAYOUT=true

# Anthropic
ANTHROPIC_API_KEY=sk-ant-replace_me

# Frontend origin during dev (Live Server / Vite / whatever you serve index.html with)
FRONTEND_ORIGIN=http://127.0.0.1:5500
